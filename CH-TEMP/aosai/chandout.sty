\ProvidesPackage{chandout}[2025/12/09 v1.1 排版中文讲义]
%
\RequirePackage{fancyhdr}
\RequirePackage{lipsum}
\RequirePackage{lastpage}
\RequirePackage{atbegshi}
\RequirePackage{zref-savepos}
\RequirePackage{dashrule}
\RequirePackage{orcidlink}
\RequirePackage{marvosym}
\RequirePackage{adforn}
%
%  选项处理
\newif\ifchandoutJS
\newif\ifchandoutZC
%
% 默认模式
\chandoutJStrue
\chandoutZCfalse

% 定义选项
\DeclareOption{jingsai}{%
    \chandoutJStrue
    \chandoutZCfalse
    \PackageInfo{chandout}{竞赛模式已激活}
}
\DeclareOption{zhouce}{%
    \chandoutJSfalse
    \chandoutZCtrue
    \PackageInfo{chandout}{周测模式已激活}
}

% 处理未知选项
\DeclareOption*{\PackageWarning{chandout}{未知选项 '\CurrentOption'，将使用默认竞赛模式}}

% 选项生效
\ProcessOptions\relax

% 定义计数器
\newcounter{fpage}
\newcounter{spage}
\newcounter{fspage}
\newcounter{fspages}

% 定义试题、答案、答题纸的页码
\newcounter{shitipage}
\newcounter{daanpage}
\newcounter{datizhipage}

% 重置页码
\newcommand{\resetpage}{
    \setcounter{fpage}{1}
    \setcounter{spage}{2}
}
\resetpage

% 设置布尔值，判断是否加载答案和答题纸

\newbool{AnswerReady}
\newbool{SheetReady}

% 定义页眉
\newcommand{\school}{\includegraphics[height=\headheight]{./logo/zb.jpg}\, 淄博实验中学}
\newcommand{\fhtitle}{物理竞赛}
\newcommand{\fhbumen}{物理竞赛原创讲义}
\newcommand{\fhmingzhi}{冯振华}
\newcommand{\fhshenhe}{冯振华}
\newcommand{\fhqi}{1}
\newcommand{\fhshijian}{2025年11月13日}
\newcommand{\fhorcid}{\orcidlink{0009-0000-2744-2368}}
\newcommand{\fhmail}{\Email\, fengzhenhua@sina.cn}
\renewcommand{\title}[1]{\renewcommand{\fhtitle}{#1}}
\renewcommand{\date}[1]{\renewcommand{\fhshijian}{#1}}
\newcommand{\mingzhi}[1]{\renewcommand{\fhmingzhi}{#1}}
\newcommand{\shenhe}[1]{\renewcommand{\fhshenhe}{#1}}
\newcommand{\bumen}[1]{\renewcommand{\fhbumen}{#1}}
\newcommand{\qi}[1]{\renewcommand{\fhqi}{#1}}
\newcommand{\orcid}[1]{\renewcommand{\fhorcid}{\orcidlink{#1}\,#1}}
\newcommand{\email}[1]{\renewcommand{\fhmail}{\Email\,#1}}
\orcid{0009-0000-2744-2368}
%
% 定义总面码
\newcommand{\shititag}{}
% 定义页脚
\newcommand{\chofoot}{
    \fancyfoot[L]{\parbox[C]{0.5\textwidth}{
            \ifnum\value{fspage}<\value{fpage}
                \relax
            \else
                \centering{}\shititag\,第\thefpage{}页\,{}共\thefspage{}页
            \fi
    }\addtocounter{fpage}{2}}
    \fancyfoot[R]{\parbox[C]{0.5\textwidth}{
            \ifnum\value{fspage}<\value{spage}
                \relax
            \else
                \centering{}\shititag\,第\thespage{}页\,{}共\thefspage{}页
            \fi
    }\addtocounter{spage}{2}}
}
\ifchandoutJS
    \renewcommand{\chofoot}{
        \fancyfoot[L]{\parbox[C]{0.5\textwidth}{
                \ifnum\value{fspage}<\value{fpage}
                    \relax
                \else
                    \centering{}\adfflowerright\,第\thefpage{}页\adfast{1}共\thefspage{}页\,\adfflowerleft
                \fi
        }\addtocounter{fpage}{2}}
        \fancyfoot[R]{\parbox[C]{0.5\textwidth}{
                \ifnum\value{fspage}<\value{spage}
                    \relax
                \else
                    \centering{}\adfflowerright\,第\thespage{}页\adfast{1}共\thefspage{}页\,\adfflowerleft
                \fi
        }\addtocounter{spage}{2}}
    }
\fi
%
\makeatletter
% 定义在栏末尾添加标记的命令
\newcommand{\columnendmark}{%
    \zsavepos{column-end-\thepage-\if@firstcolumn 1\else 2\fi}%
    \ifbool{SheetReady}{
        \ifbool{AnswerReady}{
            \if@firstcolumn
                \setcounter{fspages}{\thefpage-\thedaanpage}
            \else
                \setcounter{fspages}{\thespage-\thedaanpage}
            \fi
        }{
            \if@firstcolumn
                \setcounter{fspages}{\thefpage-\theshitipage}
            \else
                \setcounter{fspages}{\thespage-\theshitipage}
            \fi
        }
    }{
        \if@firstcolumn
            \setcounter{fspages}{\thefpage}
        \else
            \setcounter{fspages}{\thespage}
        \fi
    }
}
\makeatother

% 定义新的格式
\fancypagestyle{chostyle-js}{
    \fancyhf{}
    \renewcommand{\headrulewidth}{0.4pt}
    \resetpage
    \fancyhead[L]{\school{}\fhbumen{}\,第\fhqi{}期:\fhtitle}
    \fancyhead[R]{作者:\,\fhmingzhi\,\fhorcid\,\fhmail}
    % \fancyhead[R]{\WritingHand\,\fhmingzhi\,\fhorcid\,\fhmail}
    \chofoot
}

\fancypagestyle{chostyle-zc}{
    \fancyhf{}
    \renewcommand{\headrulewidth}{0.4pt}
    \resetpage
    \fancyhead[L]{\school{}\fhbumen{}\,第\fhqi{}期}
    \fancyhead[R]{命制人：\fhmingzhi\quad{}审核人：\fhshenhe}
    \chofoot
}

\fancypagestyle{chosheet}{
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \resetpage
    \chofoot
}

% 自动在每栏末尾添加标记
\AtEndDocument{%
    \columnendmark
    \ifbool{AnswerReady}{
        \immediate\write\pagefile{\string\setcounter{daanpage}{\thefspages}}
    }{
        \ifbool{SheetReady}{
            \immediate\write\pagefile{\string\setcounter{datizhipage}{\thefspages}}
        }{
            \immediate\write\pagefile{\string\setcounter{shitipage}{\thefspages}}
        }
    }
}
\newwrite{\pagefile}
\newcommand{\setchostyle}{
    \ifchandoutJS
        \pagestyle{chostyle-js}
    \else
        \pagestyle{chostyle-zc}
    \fi
}
\AtBeginDocument{%
    % 设置试卷主题
    \setchostyle
    % 设置答案和答题纸总页码
    \boolfalse{AnswerReady}
    \boolfalse{SheetReady}
    \IfFileExists{./chopage.aux}{
        \input{./chopage.aux}
        \setcounter{fspage}{\theshitipage}
    }{
        \relax
    }
    \immediate\openout\pagefile=chopage.aux
}
\renewcommand{\maketitle}{
    % 设置标题和日期
    \begin{center}
        {\bf\Large \fhtitle}\par
        {时间：\fhshijian}
    \end{center}
}
% 定义答题纸
\newcommand{\choinfo}{
    \noindent
    \makebox[0pt][r]{
        \rotatebox{90}{
            \makebox[0.90\textheight][c]{
                姓名：\rule{2cm}{0.4pt}\qquad
                年级：\rule{2cm}{0.4pt}\qquad
                班级：\rule{2cm}{0.4pt}\qquad
                考号：\rule{2cm}{0.4pt}\qquad
                日期：\rule{2cm}{0.4pt}
                \hfill
            }
        }
    }
}
% 重新定义\vrule
\newcounter{inum}
\setcounter{inum}{0}
\newcommand{\answersheet}[1]{
    \columnendmark
    \ifbool{AnswerReady}{
        \immediate\write\pagefile{\string\setcounter{daanpage}{\thefspages}}
    }{
        \immediate\write\pagefile{\string\setcounter{shitipage}{\thefspages}}
    }
    \clearpage
    \setlength{\columnseprule}{0.4pt}
    \boolfalse{AnswerReady}
    \booltrue{SheetReady}
    \pagestyle{chosheet}
    \renewcommand{\shititag}{答题纸}
    \setcounter{fspage}{\thedatizhipage}
    \section*{\fhtitle{}答题纸}
    \choinfo
    \clearpage
    \loop
    \stepcounter{inum}
    \ifnum\value{inum}<#1
        \choinfo
        \clearpage
    \repeat
}

% 定义答案

\newcommand{\answer}{
    \columnendmark
    \ifbool{SheetReady}{
        \immediate\write\pagefile{\string\setcounter{datizhipage}{\thefspages}}
    }{
        \immediate\write\pagefile{\string\setcounter{shitipage}{\thefspages}}
    }
    \booltrue{AnswerReady}
    \boolfalse{SheetReady}
    \clearpage
    \setchostyle
    \renewcommand{\shititag}{答案}
    \setcounter{fspage}{\thedaanpage}
    \newpage
    \section*{\fhtitle{}参考答案}
}

